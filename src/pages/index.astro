---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mayck Santos | Desenvolvedor & Engenharia" canonical="https://mayck-eduardo.web.app/">

  <div class="preloader">
    <div class="preloader-text">
      <span>MAYCK</span>
      <span>SANTOS</span>
      <span>©2026</span>
    </div>
  </div>

  <div class="cursor"></div>
  <img src="" class="hover-img" alt="Project Preview">

  <div class="content">
    <header>
      <div class="top-bar">
        <span>ENGENHARIA DA COMPUTAÇÃO</span>
        <span>VOTUPORANGA - SP</span>
      </div>
      <div class="hero-main">
        <h1 class="reveal">MAYCK<br />SANTOS</h1>
        <p class="reveal">Web Developer • Web Designer • Músico</p>
      </div>
    </header>

    <div class="marquee-container">
      <div class="marquee-content">
        JAVA • PYTHON • REACT NATIVE • HTML5 • CSS3 • MYSQL • WORDPRESS • VIOLINO & GUITARRA •
        JAVA • PYTHON • REACT NATIVE • HTML5 • CSS3 • MYSQL • WORDPRESS • VIOLINO & GUITARRA •
      </div>
    </div>

    <section class="about-me">
      <div class="label">SOBRE MIM</div>
      <div class="about-grid">
        <p class="bio">
          Sou estudante de <strong>Engenharia da Computação</strong> com uma forte paixão por criar interfaces modernas e criativas.
          Minha jornada na tecnologia começou no curso técnico do SENAI e hoje atuo como Desenvolvedor Web.
          <br /><br />
          Acredito que um bom código é como uma boa música: exige disciplina, criatividade e atenção aos detalhes.
        </p>
        <div class="skills-card">
          <h4>Minha Stack</h4>
          <div class="tags">
            <span>Java</span>
            <span>React</span>
            <span>TypeScript</span>
            <span>Python</span>
            <span>MySQL</span>
            <span>HTML/CSS</span>
            <span>WordPress</span>
          </div>
        </div>
      </div>
    </section>

    <section class="experience">
      <div class="label">EXPERIÊNCIA PROFISSIONAL</div>
      <div class="project-row no-hover exp-card">
        <div class="p-info">
          <h2>GD VIRTUAL</h2>
          <h3>Desenvolvedor & Web Designer</h3>
          <p class="role-desc">
            Atuação direta no desenvolvimento e manutenção de soluções web para clientes.
            Foco em otimização de performance, criação de interfaces responsivas e manutenção contínua de sites
            para garantir a melhor experiência do usuário final.
          </p>
        </div>
        <div class="p-year">JAN 2025 - ATUAL</div>
      </div>
    </section>

    <section class="education">
      <div class="label">FORMAÇÃO ACADÊMICA</div>
      <div class="edu-item">
        <span class="year">2025 - PRESENTE</span>
        <div class="details">
          <h3>Engenharia da Computação</h3>
          <p>UNIFEV - Centro Universitário de Votuporanga</p>
        </div>
      </div>
      <div class="edu-item">
        <span class="year">2023 - 2024</span>
        <div class="details">
          <h3>Técnico em Desenv. de Sistemas</h3>
          <p>SENAI</p>
        </div>
      </div>
      <div class="edu-extra">
        <h4>CERTIFICAÇÕES:</h4>
        <p>Java Foundations (Oracle) • Power BI (Senac) • Azure AZ-900 (Microsoft) • Cybersecurity (Cisco)</p>
      </div>
    </section>

    <section class="work">
      <div class="label">PROJETOS DE CÓDIGO</div>

      <a href="/cifrador" class="project-row hover-trigger"
        data-image="https://cifrador-chi.vercel.app/og-image.png">
        <div class="p-info">
          <h2>CIFRADOR</h2>
          <p>Next.js 16 (Automação de Cifras Musicais → DOCX/PDF)</p>
        </div>
        <div class="p-year">2025</div>
      </a>

      <a href="/cifrador-mobile" class="project-row hover-trigger"
        data-image="https://placehold.co/600x400/1a1a2e/e1e1e1?text=Cifras+Mobile">
        <div class="p-info">
          <h2>CIFRAS MOBILE</h2>
          <p>React Native (App Nativo para Músicos)</p>
        </div>
        <div class="p-year">2025</div>
      </a>

      <a href="/contador" class="project-row hover-trigger"
        data-image="https://github.com/user-attachments/assets/17826c65-13e3-4b50-9d30-432c6a404e96">
        <div class="p-info">
          <h2>CONTADOR</h2>
          <p>React Native App (Rastreador de Dias & Hábitos)</p>
        </div>
        <div class="p-year">2026</div>
      </a>

      <a href="/daytracker" class="project-row hover-trigger"
        data-image="https://placehold.co/600x400/0f172a/e1e1e1?text=Day+Tracker">
        <div class="p-info">
          <h2>DAY TRACKER</h2>
          <p>React Native (Progresso do Dia & Céu Dinâmico)</p>
        </div>
        <div class="p-year">2025</div>
      </a>

      <a href="/banda" class="project-row hover-trigger"
        data-image="https://placehold.co/600x400/1e1b4b/e1e1e1?text=Banda+App">
        <div class="p-info">
          <h2>BANDA</h2>
          <p>React Native (Gestão de Banda & Ensaios)</p>
        </div>
        <div class="p-year">2025</div>
      </a>

      <a href="https://github.com/Mayck-E" target="_blank" rel="noopener noreferrer" class="project-row hover-trigger"
        data-image="https://placehold.co/600x400/0a0a0a/FFF?text=Este+Portfolio">
        <div class="p-info">
          <h2>MEU PORTFÓLIO</h2>
          <p>Vite + GSAP + TypeScript (Alta Performance)</p>
        </div>
        <div class="p-year">2025</div>
      </a>

      <a href="/evofit" class="project-row hover-trigger" data-image="/app.jpeg">
        <div class="p-info">
          <h2>EVOFIT</h2>
          <p>React Native App (Gestão de Treinos)</p>
        </div>
        <div class="p-year">2025</div>
      </a>

      <a href="/estoque" class="project-row hover-trigger" data-image="/estoque.png">
        <div class="p-info">
          <h2>SISTEMA DE ESTOQUE</h2>
          <p>PHP + MySQL (Controle de entrada e saída)</p>
        </div>
        <div class="p-year">2024</div>
      </a>

      <a href="/station-magic" class="project-row hover-trigger"
        data-image="https://placehold.co/600x400/10b981/FFF?text=Station+Magic">
        <div class="p-info">
          <h2>STATION MAGIC</h2>
          <p>Front-end Development</p>
        </div>
        <div class="p-year">2023</div>
      </a>
    </section>

    <footer>
      <div class="contact">
        <h2>VAMOS CONVERSAR?</h2>
        <a href="mailto:mayck22.03@hotmail.com">mayck22.03@hotmail.com</a>
        <div class="links">
          <a href="https://www.linkedin.com/in/mayck-eduardo" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/Mayck-E" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
        <div style="margin-top: 3rem;">
          <a href="/resumo.pdf" download style="display: inline-block; padding: 1rem 2rem; border: 1px solid var(--accent); color: var(--accent); border-radius: 8px; font-weight: 600; text-transform: uppercase; transition: all 0.3s ease; text-decoration: none;" id="cvBtn">Baixar Resumo / CV</a>
        </div>
        <p style="margin-top: 2rem; opacity: 0.3; font-size: 0.8rem;">Soli Deo Gloria</p>
      </div>
    </footer>
  </div>

  <script type="module" src="/src/scripts/main.ts"></script>
  <script>
    document.getElementById('cvBtn')?.addEventListener('mouseover', function() {
      this.style.background = 'var(--accent)';
      this.style.color = 'var(--bg)';
    });
    document.getElementById('cvBtn')?.addEventListener('mouseout', function() {
      this.style.background = 'transparent';
      this.style.color = 'var(--accent)';
    });
  </script>
</BaseLayout>
